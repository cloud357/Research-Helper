{
  "manifest_version": 3,
  "name": "Research Helper",
  "version": "1.0.0",
  "description": "Automatically saves quotes and generates links to sources",
  "permissions": [
    "contextMenus",
    "activeTab",
    "scripting",
    "storage"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "sidebar_action": {
    "default_panel": "sidebar.html",
    "default_title": "Research Helper Workspace"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  }
}